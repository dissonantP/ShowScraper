OPENAI_API_KEY=sk-your-key-here
SERPER_API_KEY=your-serper-api-key-here
AGENTOPS_API_KEY=your-agentops-api-key-here
SPOTIFY_CLIENT_ID=your-spotify-client-id-here
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here
HOST=0.0.0.0
PORT=8000
GCS_BUCKET_NAME=show-scraper-data
MANUAL_SHOWS_OBJECT=ManuallyAdded.json
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/showscraper-service-account.json
# Optional: local file backend for manual-show testing instead of GCS
# MANUAL_SHOWS_LOCAL_FILE=/absolute/path/to/ManuallyAdded.json
# Optional: require this token on POST /manual-shows (Bearer token or X-API-Key)
# MANUAL_SHOWS_API_TOKEN=change-me
# Required for the built-in /manual-shows-ui basic-auth form
MANUAL_SHOWS_UI_USERNAME=admin
MANUAL_SHOWS_UI_PASSWORD=change-me
